# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=

# Auto-derived from token. Set explicitly only if your token is non-standard.
# DISCORD_APP_ID=

# Instant slash command registration (recommended for dev). Leave blank for global (~1h cache).
REGISTER_GUILD_ID=

# ─── Bot ownership ───────────────────────────────────────────────────────────
# Discord application owner is auto-detected. Additional owner IDs (comma-separated):
# BOT_OWNER_IDS=

# ─── Database ────────────────────────────────────────────────────────────────
# Local:  file:./dev.db
# Docker: file:/data/state.db
DATABASE_URL=file:./dev.db

# ─── Tmux / workspace ───────────────────────────────────────────────────────
# Local:  ./workspace
# Docker: /workspace
WORKSPACE_ROOT=./workspace
TMUX_SESSION_PREFIX=claude-
CLAUDE_CMD=claude

# ─── Agents ──────────────────────────────────────────────────────────────────
# Define agents via AGENT_<NAME>=<full command>. Each room can pick an agent.
# If no AGENT_* vars are set, defaults to: claude → CLAUDE_CMD value.
# Optional per-agent system prompt: AGENT_<NAME>_PROMPT=<prompt text>
# AGENT_CLAUDE=claude --dangerously-skip-permissions
# AGENT_CODEX=codex --full-auto
# AGENT_GEMINI=gemini --yolo
# AGENT_COPILOT=gh copilot

# ─── System prompt ───────────────────────────────────────────────────────────
# Default system prompt for agents without AGENT_<NAME>_PROMPT set.
# Leave blank for built-in discord-send protocol. Set to OFF to disable injection.
# CLAUDE_SYSTEM_PROMPT=

# ─── discord-send defaults ───────────────────────────────────────────────────
# DEFAULT_CHANNEL_ID=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
