# Discord
DISCORD_TOKEN=
# DISCORD_APP_ID is optional — auto-derived from the first segment of DISCORD_TOKEN
# (base64url-decoded). Set explicitly only if your token is non-standard.
DISCORD_APP_ID=

# Optional: register slash commands to a specific guild (instant propagation,
# recommended during development). Leave blank to register globally (~1h cache).
REGISTER_GUILD_ID=

# ─── Bot ownership ──────────────────────────────────────────────────────────
# The Discord application owner (or team members) is automatically considered
# a bot owner. BOT_OWNER_IDS is an additional comma-separated list of Discord
# user IDs allowed to run /acl (manage the allowlist). Optional.
BOT_OWNER_IDS=

# Allowlist is managed entirely through Discord:
#   /acl add type:<user|role|channel> value:<id|mention>
#   /acl remove type:<...> value:<...>
#   /acl list
# DMs are not supported — guild interactions only.

# Database (Prisma + SQLite)
# Use file: protocol; path is absolute or relative to project root.
# In Docker the bot writes to /data/state.db (mounted from ./data).
DATABASE_URL=file:/data/state.db

# Tmux / workspace
WORKSPACE_ROOT=/workspace
TMUX_SESSION_PREFIX=claude-
CLAUDE_CMD=claude

# Claude system-prompt injection — bot appends this to Claude's system prompt
# via --append-system-prompt so Claude knows to use the [function-reply]
# protocol. Leave blank to keep the built-in default; set to empty string in
# code (i.e. CLAUDE_SYSTEM_PROMPT="") to disable injection entirely.
CLAUDE_SYSTEM_PROMPT=

# Verbose output: when true, the raw tmux pane is also streamed to Discord as
# code blocks (useful for debugging). When false (default), only Claude's
# [function-reply] messages and menu prompts reach Discord.
VERBOSE_OUTPUT=false

# Capture / chunking
# Polling-based output streaming; tune lower for snappier replies, higher to
# reduce CPU + Discord rate-limit pressure. Default 400 ms ≈ ~3-4 s end-to-end
# latency (poll + 2-round idle confirm).
CAPTURE_POLL_MS=400
IDLE_CONFIRM_ROUNDS=2
MAX_OUTPUT_CHUNK=1900
LONG_RUN_WARN_MS=120000
HARD_TIMEOUT_MS=600000

# Default channel for send.js when -c is omitted. Optional.
DEFAULT_CHANNEL_ID=

# Logging (pino level: trace|debug|info|warn|error|fatal)
LOG_LEVEL=info
